# Copy to `.env`
PORT=5050
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/skilltrove

JWT_SECRET=replace-with-strong-secret-at-least-32-chars
JWT_EXPIRY=7d

# OpenAI AI quiz + rubric grading
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Gemini alternative (passed as provider=g in generate endpoint)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

CORS_ORIGIN=*
